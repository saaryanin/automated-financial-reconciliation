# Ignore venv and Python cache
venv/
__pycache__/
*.pyc
*.pyo
*.log

# Ignore all files inside data/, but not the folders themselves or .gitkeep files
data/**
!data/
!data/**/
!data/**/.gitkeep

# Ignore all files inside output/, but not the folders themselves or .gitkeep files
output/**
!output/
!output/**/
!output/**/.gitkeep
